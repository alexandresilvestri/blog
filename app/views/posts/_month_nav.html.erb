<ul class="space-y-2">
  <% @posts_by_month.each_key do |month| %>
    <li>
      <%=
        link_to l(month, format: '%Y - %B'),
                "##{month.strftime('%Y-%m')}",
                data: { action: 'click->sidebar#close' },
                class:
                  'text-brand-500 text-lg dark:text-brand-400 hover:text-accent hover:font-bold transition-colors'
      %>
    </li>
  <% end %>
</ul>
