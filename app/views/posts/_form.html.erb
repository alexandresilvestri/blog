<%= form_with model: post, class: "space-y-8" do |f| %>
  <% if post.errors.any? %>
    <div
      class="rounded border border-red-200 bg-red-50 p-4 text-sm text-red-700"
    >
      <p class="font-medium mb-1">
        <%= pluralize(post.errors.count, 'error') %> stopped this post from
        saving:
      </p>
      <ul class="list-disc list-inside">
        <% post.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%=
      f.label :title,
              class:
                'block text-xs uppercase tracking-widest text-brand-400 dark:text-brand-500 mb-2'
    %>
    <%=
      f.text_field :title,
                   class:
                     'w-full bg-transparent border-b border-brand-300 dark:border-brand-700 focus:border-accent focus:outline-none py-2 font-serif text-2xl text-brand-900 dark:text-brand-100 placeholder-brand-300 dark:placeholder-brand-600',
                   placeholder: 'Title'
    %>
  </div>

  <div>
    <%=
      f.label :body,
              class:
                'block text-xl uppercase tracking-widest text-brand-400 dark:text-brand-500 mb-2'
    %>
    <%=
      f.rich_text_area :body,
                       class:
                         'trix-content w-full bg-transparent text-brand-700 dark:text-brand-300 leading-relaxed'
    %>
  </div>

  <div class="flex items-center gap-4 pt-2">
    <%=
      f.submit submit_label,
               class:
                 'text-sm text-accent hover:text-accent-dark border-b border-accent-light hover:border-b-2 cursor-pointer'
    %>
    <%=
      link_to 'Cancel',
              posts_path,
              class:
                'text-sm text-brand-400 dark:text-brand-500 hover:text-brand-600 dark:hover:text-brand-300'
    %>
  </div>
<% end %>
