<article class="max-w-prose mx-auto">
  <header class="mb-10 border-b border-brand-200 dark:border-brand-800 pb-6">
    <time
      class="block text-xs uppercase tracking-widest text-brand-400 dark:text-brand-500 mb-2"
    >
      <%= @post.created_at.strftime('%B %d, %Y') %>
    </time>
    <h1
      class="font-serif text-4xl font-bold text-brand-900 dark:text-brand-100 tracking-tight leading-tight"
    >
      <%= @post.title %>
    </h1>
  </header>

  <div
    class="text-xl prose dark:prose-invert trix-content text-brand-700 dark:text-brand-300 leading-relaxed"
  >
    <%= @post.body %>
  </div>

  <footer
    class="mt-12 flex items-center gap-4 border-t border-brand-200 dark:border-brand-800 pt-6"
  >
    <%=
      link_to '← All posts',
              posts_path,
              class:
                'text-lg text-accent border-b border-accent-light hover:border-b-2'
    %>
    <% if user_signed_in? %>
      <div class="flex items-center gap-4 ml-auto">
        <%=
          link_to edit_post_path(@post),
                  'aria-label': 'Edit',
                  class:
                    'text-brand-400 dark:text-brand-500 hover:text-accent transition-colors' do
        %>
          <%= icon 'pencil-square', class: 'w-5 h-5' %>
        <% end %>
        <%= button_to @post, method: :delete,
          form_class: 'inline-flex',
          'aria-label': 'Delete',
          data: { turbo_confirm: 'Confirme a exclusão' },
          class: 'text-brand-400 dark:text-brand-500 hover:text-red-600 transition-colors' do %>
          <%= icon 'trash', class: 'w-5 h-5' %>
        <% end %>
      </div>
    <% end %>
  </footer>
</article>
