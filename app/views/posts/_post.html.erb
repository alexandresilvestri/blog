<li class="leading-relaxed">
  <%=
    link_to post.title,
            post,
            class:
              'font-serif text-brand-800 dark:text-brand-200 hover:text-accent transition-colors'
  %>
  <% if user_signed_in? %>
    <%= button_to post, method: :delete,
      form_class: 'inline-block align-middle ml-2',
      data: { turbo_confirm: 'Confirme a exclusão' },
      class: 'text-brand-400 dark:text-brand-500 hover:text-red-600 transition-colors' do %>
      <%= icon 'trash', class: 'w-4 h-4' %>
    <% end %>
  <% end %>
</li>
