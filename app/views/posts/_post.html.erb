<li class="py-8">
   <article class="flex justify-between w-full group">
      <div>
        <time class="block text-xs uppercase tracking-widest text-brand-400 mb-2">
          <%= post.created_at.strftime("%B %d, %Y") %>
        </time>
        <h2 class="font-serif text-2xl font-semibold text-brand-900 mb-3 leading-snug">
          <%= link_to post.title, post, class: "hover:text-accent transition-colors" %>
        </h2>
        <p class="text-brand-600 leading-relaxed">
          <%= truncate(post.post.to_s, length: 180, separator: " ") %>
        </p>
        <%= link_to post, class: "inline-block mt-3 text-sm text-accent border-b border-accent-light hover:border-b-2" do %>
          Read more &rarr;
        <% end %>
      </div>
      <div>
        <%= button_to post, method: :delete, 
          data: { turbo_confirm: 'Confirme a exclusão' }, 
          class: 'inline-flex items-center gap-1.5 text-sm text-brand-500 hover:text-red-600 transition-colors' do %>
          <%= icon 'trash', class: 'w-4 h-4' %>
          Deletar post
        <% end %>
      </div>
    </article>
</li>
