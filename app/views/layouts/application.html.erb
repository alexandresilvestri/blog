<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || 'Alexandre Silvestri' %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="application-name" content="Alexandre Silvestri" />
    <meta name="mobile-web-app-capable" content="yes" />
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/fox.png" type="image/png" />
    <link rel="fox-icon" href="/fox.png" />
    <link rel="github-icon" href="/github.png" />
    <link rel="gitlab-icon" href="/gitlab.png" />

    <%= javascript_tag nonce: true do %>
      (function () { var dark = localStorage.getItem('theme') === 'dark';
      document.documentElement.classList.toggle('dark', dark); })();
    <% end %>

    <%= preload_link_tag asset_path('InterVariable.woff2'), as: 'font', type: 'font/woff2', crossorigin: 'anonymous' %>
    <%= stylesheet_link_tag 'tailwind', 'data-turbo-track': 'reload' %>
    <%= stylesheet_link_tag 'actiontext', 'data-turbo-track': 'reload' %>
    <%= javascript_importmap_tags %>
  </head>

  <body
    data-controller="sidebar"
    class="font-sans text-gray-800 bg-white dark:bg-brand-900 dark:text-brand-100"
  >
    <header class="border-b border-gray-200 dark:border-brand-800">
      <div class="flex justify-between w-full px-4 py-4">
        <div>
          <%= link_to root_path, class: "flex itens-center gap-2 text-left text-2xl font-serif font-bold text-brand-900 dark:text-brand-100" do %>
            <%= image_tag '/fox.png', alt: 'Fox', class: 'w-8 h-8 shrink-0' %>
            <h1 class="hidden sm:block">Alexandre Silvestri</h1>
          <% end %>
        </div>
        <div class="flex gap-4 items-center">
          <div class="hidden lg:flex gap-4 items-center">
            <%= render 'layouts/nav_icons' %>
          </div>
          <%= yield :header_actions %>
          <% if user_signed_in? %>
            <div class="flex items-center">
              <%=
                button_to 'Sign out',
                          session_path,
                          method: :delete,
                          class:
                            'text-sm text-brand-500 dark:text-brand-400 hover:text-accent'
              %>
            </div>
          <% end %>
        </div>
      </div>
    </header>

    <main class="max-w-container mx-auto px-4 py-12">
      <% flash.each do |type, message| %>
        <div
          class="mb-6 text-sm <%= type.to_s == 'alert' ? 'text-red-600' : 'text-brand-600' %>"
        >
          <%= message %>
        </div>
      <% end %>
      <%= yield %>
    </main>
  </body>
</html>
